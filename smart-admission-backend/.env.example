# ── Copy this file to .env and fill in your values ──

# Flask
FLASK_ENV=development
SECRET_KEY=your-super-secret-key-here

# Database (SQLite by default, switch to PostgreSQL for production)
DATABASE_URL=sqlite:///smart_admission.db
# DATABASE_URL=postgresql://user:password@localhost:5432/smart_admission

# Anthropic Claude API  ← GET FROM https://console.anthropic.com
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# JWT
JWT_SECRET_KEY=your-jwt-secret-here
JWT_ACCESS_TOKEN_EXPIRES=86400

# Email (optional)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
